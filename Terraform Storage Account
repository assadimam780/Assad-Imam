terraform {
  required_providers {
    azurerm={
        source = "hashicorp/azurerm"
        version = "4.66.0"
    }
  }
}
provider "azurerm" {
  features {
    
  }
}
resource "azurerm_resource_group" "march" {
  name = "azad"
  location = "eastus"
}

resource "azurerm_storage_account" "april"  {
name = "booked"
  resource_group_name = "azad"
  location = "eastus2"
  account_tier = "Standard"
  account_replication_type = "LRS"
  depends_on = [azurerm_resource_group.march]
}
